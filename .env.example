# ThreadGrade API Keys
# Copy this file to .env and fill in your keys

# Anthropic Claude API key (for sustainability report parsing)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# DOL Data Portal API key (free — register at https://dataportal.dol.gov/registration)
# Required for OSHA enforcement data scraper
DOL_API_KEY=your-dol-api-key-here

# Open Supply Hub API token (free — sign up at https://opensupplyhub.org)
# Generate at: My Account > Settings > API > Generate New API Token
OSH_API_TOKEN=your-osh-api-token-here
